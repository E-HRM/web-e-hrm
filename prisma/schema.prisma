  otp_expires_at   DateTime? @db.DateTime(0)
  otp_verified_at  DateTime? @db.DateTime(0)
  otp_attempts     Int       @default(0)

  created_at DateTime  @default(now()) @db.DateTime(0)
  updated_at DateTime  @updatedAt @db.DateTime(0)
  deleted_at DateTime? @db.DateTime(0)

  payroll_karyawan PayrollKaryawan @relation(fields: [id_payroll_karyawan], references: [id_payroll_karyawan], onDelete: Cascade, onUpdate: Cascade)
  approver         User?           @relation("ApprovalPayrollKaryawan_approver", fields: [approver_user_id], references: [id_user], onDelete: Restrict, onUpdate: Cascade)

  @@unique([id_payroll_karyawan, level], name: "uniq_approval_payroll_karyawan_level")
  @@index([id_payroll_karyawan])
  @@index([approver_user_id])
  @@index([decision])
  @@index([otp_verified_at])
  @@index([deleted_at])
  @@map("approval_payroll_karyawan")
}

model PinjamanKaryawan {
  id_pinjaman_karyawan String         @id @default(uuid()) @db.Char(36)
  id_user              String         @db.Char(36)
  nama_pinjaman        String         @db.VarChar(255)
  nominal_pinjaman     Decimal        @db.Decimal(15, 2)
  tenor_bulan          Int
  sisa_saldo           Decimal        @db.Decimal(15, 2)
  tanggal_mulai        DateTime       @db.Date
  tanggal_selesai      DateTime?      @db.Date
  status_pinjaman      StatusPinjaman @default(AKTIF)
  catatan              String?        @db.LongText

  created_at DateTime  @default(now()) @db.DateTime(0)
  updated_at DateTime  @updatedAt @db.DateTime(0)
  deleted_at DateTime? @db.DateTime(0)

  user    User                      @relation(fields: [id_user], references: [id_user], onDelete: Restrict, onUpdate: Cascade)
  cicilan CicilanPinjamanKaryawan[]

  @@index([id_user, status_pinjaman])
  @@index([deleted_at])
  @@map("pinjaman_karyawan")
}

model CicilanPinjamanKaryawan {
  id_cicilan_pinjaman_karyawan String  @id @default(uuid()) @db.Char(36)
  id_pinjaman_karyawan         String  @db.Char(36)
  id_payroll_karyawan          String? @db.Char(36)

  jatuh_tempo      DateTime              @db.Date
  nominal_tagihan  Decimal               @db.Decimal(15, 2)
  nominal_terbayar Decimal               @default(0) @db.Decimal(15, 2)
  status_cicilan   StatusCicilanPinjaman @default(MENUNGGU)

  diposting_pada DateTime? @db.DateTime(0)
  dibayar_pada   DateTime? @db.DateTime(0)
  catatan        String?   @db.LongText

  created_at DateTime  @default(now()) @db.DateTime(0)
  updated_at DateTime  @updatedAt @db.DateTime(0)
  deleted_at DateTime? @db.DateTime(0)

  pinjaman_karyawan PinjamanKaryawan @relation(fields: [id_pinjaman_karyawan], references: [id_pinjaman_karyawan], onDelete: Cascade, onUpdate: Cascade)
  payroll_karyawan  PayrollKaryawan? @relation(fields: [id_payroll_karyawan], references: [id_payroll_karyawan], onDelete: SetNull, onUpdate: Cascade)

  @@index([id_pinjaman_karyawan, jatuh_tempo])
  @@index([id_payroll_karyawan])
  @@index([status_cicilan])
  @@index([deleted_at])
  @@map("cicilan_pinjaman_karyawan")
}

model PeriodeKonsultan {
  id_periode_konsultan String                 @id @default(uuid()) @db.Char(36)
  tahun                Int
  bulan                Bulan
  tanggal_mulai        DateTime               @db.Date
  tanggal_selesai      DateTime               @db.Date
  status_periode       StatusPeriodeKonsultan @default(DRAFT)
  catatan              String?                @db.LongText

  created_at DateTime  @default(now()) @db.DateTime(0)
  updated_at DateTime  @updatedAt @db.DateTime(0)
  deleted_at DateTime? @db.DateTime(0)

  transaksi_konsultan TransaksiKonsultan[]
  payout_konsultan    PayoutKonsultan[]

  @@unique([tahun, bulan], name: "uniq_periode_konsultan")
  @@index([status_periode])
  @@index([deleted_at])
  @@map("periode_konsultan")
}

model JenisProdukKonsultan {
  id_jenis_produk_konsultan String   @id @default(uuid()) @db.Char(36)
  nama_produk               String   @db.VarChar(255)
  persen_share_default      Decimal? @db.Decimal(7, 4)
  aktif                     Boolean  @default(true)
  catatan                   String?  @db.LongText

  created_at DateTime  @default(now()) @db.DateTime(0)
  updated_at DateTime  @updatedAt @db.DateTime(0)
  deleted_at DateTime? @db.DateTime(0)

  transaksi_konsultan TransaksiKonsultan[]

  @@unique([nama_produk], name: "uniq_nama_produk_konsultan")
  @@index([aktif])
  @@index([deleted_at])
  @@map("jenis_produk_konsultan")
}

model TransaksiKonsultan {
  id_transaksi_konsultan    String  @id @default(uuid()) @db.Char(36)
  id_periode_konsultan      String  @db.Char(36)
  id_user_konsultan         String? @db.Char(36)
  id_jenis_produk_konsultan String? @db.Char(36)

  tanggal_transaksi DateTime @db.Date
  nama_klien        String?  @db.VarChar(255)
  deskripsi         String?  @db.LongText

  nominal_debit  Decimal @default(0) @db.Decimal(15, 2)
  nominal_kredit Decimal @default(0) @db.Decimal(15, 2)
  total_income   Decimal @default(0) @db.Decimal(15, 2)

  persen_share_default  Decimal? @db.Decimal(7, 4)
  persen_share_override Decimal? @db.Decimal(7, 4)
  nominal_share         Decimal  @default(0) @db.Decimal(15, 2)
  nominal_oss           Decimal  @default(0) @db.Decimal(15, 2)

  override_manual       Boolean @default(false)
  sudah_posting_payroll Boolean @default(false)
  catatan               String? @db.LongText

  created_at DateTime  @default(now()) @db.DateTime(0)
  updated_at DateTime  @updatedAt @db.DateTime(0)
  deleted_at DateTime? @db.DateTime(0)

  periode_konsultan PeriodeKonsultan        @relation(fields: [id_periode_konsultan], references: [id_periode_konsultan], onDelete: Cascade, onUpdate: Cascade)
  konsultan         User?                   @relation("TransaksiKonsultan_konsultan", fields: [id_user_konsultan], references: [id_user], onDelete: SetNull, onUpdate: Cascade)
  jenis_produk      JenisProdukKonsultan?   @relation(fields: [id_jenis_produk_konsultan], references: [id_jenis_produk_konsultan], onDelete: SetNull, onUpdate: Cascade)
  payout_detail     PayoutKonsultanDetail[]

  @@index([id_periode_konsultan, tanggal_transaksi])
  @@index([id_user_konsultan, tanggal_transaksi])
  @@index([id_jenis_produk_konsultan])
  @@index([deleted_at])
  @@map("transaksi_konsultan")
}

model PayoutKonsultan {
  id_payout_konsultan  String  @id @default(uuid()) @db.Char(36)
  id_periode_konsultan String  @db.Char(36)
  id_user              String  @db.Char(36)
  id_periode_payroll   String? @db.Char(36)

  total_share         Decimal @db.Decimal(15, 2)
  nominal_ditahan     Decimal @default(0) @db.Decimal(15, 2)
  nominal_penyesuaian Decimal @default(0) @db.Decimal(15, 2)
  nominal_dibayarkan  Decimal @db.Decimal(15, 2)

  status_payout  StatusPayoutKonsultan @default(DRAFT)
  disetujui_pada DateTime?             @db.DateTime(0)
  diposting_pada DateTime?             @db.DateTime(0)
  catatan        String?               @db.LongText

  created_at DateTime  @default(now()) @db.DateTime(0)
  updated_at DateTime  @updatedAt @db.DateTime(0)
  deleted_at DateTime? @db.DateTime(0)

  periode_konsultan PeriodeKonsultan        @relation(fields: [id_periode_konsultan], references: [id_periode_konsultan], onDelete: Cascade, onUpdate: Cascade)
  periode_payroll   PeriodePayroll?         @relation(fields: [id_periode_payroll], references: [id_periode_payroll], onDelete: SetNull, onUpdate: Cascade)
  user              User                    @relation(fields: [id_user], references: [id_user], onDelete: Restrict, onUpdate: Cascade)
  payout_detail     PayoutKonsultanDetail[]

  @@unique([id_periode_konsultan, id_user], name: "uniq_payout_konsultan_per_periode")
  @@index([id_periode_payroll])
  @@index([status_payout])
  @@index([deleted_at])
  @@map("payout_konsultan")
}

model PayoutKonsultanDetail {
  id_payout_konsultan_detail String @id @default(uuid()) @db.Char(36)
  id_payout_konsultan        String @db.Char(36)
  id_transaksi_konsultan     String @db.Char(36)

  nominal_share Decimal @default(0) @db.Decimal(15, 2)
  nominal_oss   Decimal @default(0) @db.Decimal(15, 2)
  ditahan       Boolean @default(false)
  catatan       String? @db.LongText

  created_at DateTime  @default(now()) @db.DateTime(0)
  updated_at DateTime  @updatedAt @db.DateTime(0)
  deleted_at DateTime? @db.DateTime(0)

  payout    PayoutKonsultan    @relation(fields: [id_payout_konsultan], references: [id_payout_konsultan], onDelete: Cascade, onUpdate: Cascade)
  transaksi TransaksiKonsultan @relation(fields: [id_transaksi_konsultan], references: [id_transaksi_konsultan], onDelete: Restrict, onUpdate: Cascade)

  @@unique([id_payout_konsultan, id_transaksi_konsultan], name: "uniq_payout_transaksi")
  @@index([id_transaksi_konsultan])
  @@index([deleted_at])
  @@map("payout_konsultan_detail")
}

model KPI {
  id_kpi         String       @id @default(uuid()) @db.Char(36)
  kode_kpi       String?      @unique @db.VarChar(100)
  nama_kpi       String       @db.VarChar(255)
  deskripsi      String?      @db.LongText
  default_satuan String?      @db.VarChar(100)
  value_type     KPIValueType @default(number)

  created_at DateTime  @default(now()) @db.DateTime(0)
  updated_at DateTime  @updatedAt @db.DateTime(0)
  deleted_at DateTime? @db.DateTime(0)

  kpi_jabatans KPIJabatan[]
  plan_items   KPIPlanItem[]

  @@index([nama_kpi])
  @@map("kpi")
}

model KPIJabatan {
  id_kpi_jabatan  String   @id @default(uuid()) @db.Char(36)
  id_kpi          String   @db.Char(36)
  id_jabatan      String   @db.Char(36)
  urutan          Int      @default(0)
  target_default  Decimal? @db.Decimal(18, 2)
  satuan_override String?  @db.VarChar(100)
  bobot           Decimal? @db.Decimal(5, 2)
  wajib           Boolean  @default(true)

  created_at DateTime  @default(now()) @db.DateTime(0)
  updated_at DateTime  @updatedAt @db.DateTime(0)
  deleted_at DateTime? @db.DateTime(0)

  kpi     KPI     @relation(fields: [id_kpi], references: [id_kpi], onDelete: Cascade, onUpdate: Cascade)
  jabatan Jabatan @relation(fields: [id_jabatan], references: [id_jabatan], onDelete: Cascade, onUpdate: Cascade)

  @@unique([id_kpi, id_jabatan])
  @@index([id_kpi])
  @@index([id_jabatan])
  @@index([id_jabatan, urutan])
  @@map("kpi_jabatan")
}

model KPIPlan {
  id_kpi_plan String        @id @default(uuid()) @db.Char(36)
  id_user     String        @db.Char(36)
  id_jabatan  String        @db.Char(36)
  id_location String?       @db.Char(36)
  tahun       Int
  status      KPIPlanStatus @default(draft)

  nama_user_snapshot String? @db.VarChar(255)
  jabatan_snapshot   String? @db.VarChar(255)
  location_snapshot  String? @db.VarChar(255)

  created_at DateTime  @default(now()) @db.DateTime(0)
  updated_at DateTime  @updatedAt @db.DateTime(0)
  deleted_at DateTime? @db.DateTime(0)

  user    User      @relation(fields: [id_user], references: [id_user], onDelete: Cascade, onUpdate: Cascade)
  jabatan Jabatan   @relation(fields: [id_jabatan], references: [id_jabatan], onDelete: Restrict, onUpdate: Cascade)
  kantor  Location? @relation(fields: [id_location], references: [id_location], onDelete: SetNull, onUpdate: Cascade)

  items KPIPlanItem[]

  @@unique([id_user, tahun])
  @@index([id_user])
  @@index([id_jabatan, tahun])
  @@index([id_location, tahun])
  @@index([tahun, status])
  @@map("kpi_plan")
}

model KPIPlanItem {
  id_kpi_plan_item  String  @id @default(uuid()) @db.Char(36)
  id_kpi_plan       String  @db.Char(36)
  id_kpi            String  @db.Char(36)
  urutan            Int     @default(0)
  nama_kpi_snapshot String  @db.VarChar(255)
  satuan_snapshot   String? @db.VarChar(100)
  target_tahunan    Decimal @db.Decimal(18, 2)

  created_at DateTime  @default(now()) @db.DateTime(0)
  updated_at DateTime  @updatedAt @db.DateTime(0)
  deleted_at DateTime? @db.DateTime(0)

  plan KPIPlan @relation(fields: [id_kpi_plan], references: [id_kpi_plan], onDelete: Cascade, onUpdate: Cascade)
  kpi  KPI     @relation(fields: [id_kpi], references: [id_kpi], onDelete: Restrict, onUpdate: Cascade)

  terms             KPIPlanItemTerm[]
  weekly_progresses KPIPlanItemWeekProgress[]

  @@unique([id_kpi_plan, id_kpi])
  @@index([id_kpi_plan])
  @@index([id_kpi])
  @@index([id_kpi_plan, urutan])
  @@map("kpi_plan_item")
}

model KPIPlanItemTerm {
  id_kpi_plan_term String      @id @default(uuid()) @db.Char(36)
  id_kpi_plan_item String      @db.Char(36)
  term             KPITermType
  target_term      Decimal?    @db.Decimal(18, 2)
  achievement      Decimal?    @db.Decimal(18, 2)
  catatan          String?     @db.LongText

  created_at DateTime  @default(now()) @db.DateTime(0)
  updated_at DateTime  @updatedAt @db.DateTime(0)
  deleted_at DateTime? @db.DateTime(0)

  plan_item KPIPlanItem @relation(fields: [id_kpi_plan_item], references: [id_kpi_plan_item], onDelete: Cascade, onUpdate: Cascade)

  @@unique([id_kpi_plan_item, term], name: "unique_term_per_plan_item")
  @@index([id_kpi_plan_item])
  @@map("kpi_plan_item_term")
}

model KPIPlanItemWeekProgress {
  id_kpi_plan_item_week_progress String   @id @default(uuid()) @db.Char(36)
  id_kpi_plan_item               String   @db.Char(36)
  tahun                          Int
  week_start                     DateTime @db.Date
  week_end                       DateTime @db.Date
  completed_count                Int      @default(0)

  created_at DateTime @default(now()) @db.DateTime(0)
  updated_at DateTime @updatedAt @db.DateTime(0)

  plan_item KPIPlanItem @relation(fields: [id_kpi_plan_item], references: [id_kpi_plan_item], onDelete: Cascade, onUpdate: Cascade)

  @@unique([id_kpi_plan_item, week_start], name: "unique_week_progress_per_kpi_item")
  @@index([id_kpi_plan_item])
  @@index([tahun, week_start])
  @@map("kpi_plan_item_week_progress")
}
